# ─── Cloud API keys (optional — leave blank to run fully offline) ───
DEEPGRAM_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Provider selection ───
# ASR:  groq | deepgram | local | faster-whisper | mlx
#   "local" auto-picks MLX on Apple Silicon, faster-whisper elsewhere.
ASR_PROVIDER=groq
# LLM:  groq | openai | anthropic | gemini | ollama
LLM_PROVIDER=groq
# Optional model override (sensible defaults per provider otherwise)
# LLM_MODEL=

# ─── Fully-local stack example ───
# ASR_PROVIDER=local
# LLM_PROVIDER=ollama
#   (run `ollama serve` and `ollama pull llama3.2`; install ASR with
#    `uv sync --extra local --extra mlx`)

# ─── Local ASR (offline Whisper) ───
# faster-whisper size: tiny.en base.en small.en medium.en large-v3 distil-large-v3
LOCAL_ASR_MODEL=small.en
LOCAL_ASR_DEVICE=auto          # auto | cpu | cuda
LOCAL_ASR_COMPUTE_TYPE=auto    # auto | int8 | int8_float16 | float16 | float32
LOCAL_ASR_LANGUAGE=en          # ISO code, or blank for auto-detect
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# ─── Local LLM (Ollama / any OpenAI-compatible server) ───
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ─── Custom vocabulary ───
# Newline-separated terms that bias ASR and correct LLM output (names, jargon, acronyms).
DICTIONARY_PATH=dictionary.txt

# ─── Live streaming (WS mode=stream) ───
# How often to re-transcribe the active tail for live partials, and the
# minimum new audio (seconds) before spending another ASR call.
STREAM_INTERVAL_S=1.2
STREAM_MIN_NEW_S=0.8
# A pause this long finalizes ("commits") the current segment so it's never
# re-transcribed again — keeps cost bounded on long dictation.
STREAM_COMMIT_SILENCE_S=0.6
# RMS (0..1) below which audio counts as silence and ASR is skipped. Lower it
# if a quiet mic drops words; raise it if background noise gets transcribed.
STREAM_SILENCE_RMS=0.006

# ─── Server ───
HOST=127.0.0.1   # use 0.0.0.0 to expose the API to your local network
PORT=8000
LOG_LEVEL=info
